NODE_ENV=production
HOST=0.0.0.0
PORT=10000

# MongoDB Atlas
# Atlas may give you a URI like:
# mongodb+srv://<db_username>:<db_password>@cluster.pamy53z.mongodb.net/?appName=Cluster
# Replace the username/password. The backend will use MONGO_DB_NAME when the URI has no database path.
MONGO_URI=mongodb+srv://YOUR_DB_USERNAME:YOUR_DB_PASSWORD@cluster.pamy53z.mongodb.net/joybox_store?retryWrites=true&w=majority&appName=Cluster
MONGO_DB_NAME=joybox_store

STORE_NAME=JoyBox Gifts & Toys
STORE_EMAIL=your-store-email@example.com
CONTACT_TO_EMAIL=your-store-email@example.com

AUTH_TOKEN_SECRET=replace_with_a_long_random_secret
ADMIN_ID=admin
ADMIN_PASSWORD=replace_with_a_strong_admin_password
OWNER_TOKEN_SECRET=replace_with_another_long_random_secret

RAZORPAY_KEY_ID=rzp_test_or_live_key_id
RAZORPAY_KEY_SECRET=replace_with_razorpay_secret

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-store-email@example.com
SMTP_PASS=your_email_app_password
SMTP_FROM="JoyBox Website <your-store-email@example.com>"
